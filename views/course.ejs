<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title> Khóa học </title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    main{
      display: flex;
    }
    img{
      width: 280px;
     height: 280px;
      object-fit: cover;
      border-radius: 30px;
    }
    .box{
      cursor: pointer;
      margin-left: 50px;
      width: 280px;
      /* border: 1px solid black; */
      border-radius: 30px;
      overflow: hidden;
    }
    p{
      text-align: center;
      text-transform: uppercase;
      font-weight: bold;
      color: black;
    }
  </style>
</head>
<body>
  <%- include('partials/header'); %>
  
  <main>
    <div class="box">
      <img src="/image/vatlydaicuong.jpg" alt="img">
      <p> Khóa luyện thi lý đại cương 1</p>
    </div>
    <div class="box">
      <img src="/image/giaitich1.jpg" alt="img">
      <p> Khóa luyện thi giải tích 1</p>
    </div>
    <div class="box">
      <img src="/image/giaitich2.jpg" alt="img">
      <p> Khóa luyện thi giải tích 2</p>
    </div>
    <div class="box">
      <img src="/image/giaitich3.jpg" alt="img">
      <p> Khóa luyện thi giải tích 3</p>
    </div>
    <div class="box">
      <img src="/image/xacsuatthongke.jpg" alt="img">
      <p> Khóa luyện thi xác suất thống kê</p>
    </div>
  </main>

  <%- include('partials/footer'); %>
</body>
</html>